<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Recipes</title>
</head>
<body>
  <h1>Recipe List</h1>
  <ul>
    <% recipes.forEach(recipe => { %>
      <li>
        <a href="/recipe/<%= recipe.name %>"><%= recipe.name %></a>
      </li>
    <% }) %>
  </ul>
</body>
</html>
